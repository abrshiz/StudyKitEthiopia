# --- Core ----------------------------------------------------------------
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/studykit_et
CLIENT_ORIGIN=http://localhost:8080,http://localhost:8081
PUBLIC_APP_URL=http://localhost:8080

# --- Auth (JWT cookie) ---------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars
JWT_TTL_SECONDS=604800
COOKIE_NAME=sk_at
COOKIE_DOMAIN=
COOKIE_SECURE=false

# --- Microsoft OAuth (Azure AD v2.0) -------------------------------------
# Register an app at https://portal.azure.com → App registrations.
# Redirect URI must match MICROSOFT_REDIRECT_URI exactly.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/auth/microsoft/callback

# --- Gemini AI -----------------------------------------------------------
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# --- Chapa payments ------------------------------------------------------
# https://dashboard.chapa.co — copy the test keys for dev.
CHAPA_SECRET_KEY=
CHAPA_WEBHOOK_SECRET=
CHAPA_BASE_URL=https://api.chapa.co/v1
CHAPA_CALLBACK_URL=http://localhost:4000/api/chapa/webhook
CHAPA_RETURN_URL=http://localhost:8080/billing?status=success

# --- Resend (transactional email) ----------------------------------------
# https://resend.com
RESEND_API_KEY=
RESEND_FROM="StudyKit ET <no-reply@studykit.et>"

# --- File storage --------------------------------------------------------
# Local disk root (relative to server/). Uploaded materials go to
# `${UPLOADS_DIR}/<materialId>/original.<ext>`.
UPLOADS_DIR=uploads
