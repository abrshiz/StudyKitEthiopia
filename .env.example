# Frontend (Vite) — copy to .env and restart dev server
VITE_API_URL=http://localhost:4000/api

# Dev ports (both work with the API — see server CLIENT_ORIGIN):
#   npm run dev       → http://localhost:8080  (default)
#   npm run dev:8081  → http://localhost:8081
# If 8080 is busy, `npm run dev` auto-opens 8081 instead.

# API server — copy to server/.env
# PORT=4000
# MONGODB_URI=mongodb://127.0.0.1:27017/studykit_et
# CLIENT_ORIGIN=http://localhost:8080,http://localhost:8081
